# Django Configuration (NEVER COMMIT ACTUAL VALUES)
SECRET_KEY=generate-a-64-character-random-string-here
DEBUG=False

# Database Configuration
DB_NAME=selita_fish
DB_USER=selita_user
DB_PASSWORD=generate-strong-password-here
DB_HOST=db
DB_PORT=5432

# JWT Configuration
ALGORITHM=HS256

# Production domains (comma-separated)
ADDITIONAL_HOSTS=selitafish.com,www.selitafish.com
ALLOWED_DOMAINS=selitafish.com,www.selitafish.com

# Admin user (created on first startup)
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@selitafish.com
DJANGO_SUPERUSER_PASSWORD=generate-strong-password-here
