# Production environment — copy to .env.prod and fill in real values.
# NEVER commit .env.prod — it is git-ignored.

# Django
SECRET_KEY=generate-with-python3-c-import-secrets-secrets.token_urlsafe(64)
DEBUG=False

# Database
DB_NAME=erp_db
DB_USER=erp_user
DB_PASSWORD=change-me-strong-random-password
DB_HOST=db
DB_PORT=5432

# Allowed hosts (comma-separated)
ADDITIONAL_HOSTS=yourdomain.com,www.yourdomain.com
ALLOWED_DOMAINS=yourdomain.com
