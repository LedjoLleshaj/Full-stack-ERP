# =============================================================================
# PRODUCTION ENVIRONMENT CONFIGURATION
# =============================================================================
# Copy this file to .env.prod and fill in actual values
# NEVER commit .env.prod to git!
# =============================================================================

# Database
DB_NAME=selita_fish
DB_USER=selita_prod_user
DB_PASSWORD=CHANGE_THIS_GENERATE_WITH_openssl_rand_-base64_32

# Django
SECRET_KEY=CHANGE_THIS_GENERATE_WITH_python3_-c_import_secrets_print_secrets.token_urlsafe_64
DEBUG=False
ADDITIONAL_HOSTS=selitafish.com,www.selitafish.com
ALLOWED_DOMAINS=selitafish.com,www.selitafish.com

# Admin credentials (used only on first startup)
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@selitafish.com
DJANGO_SUPERUSER_PASSWORD=CHANGE_THIS_STRONG_PASSWORD
